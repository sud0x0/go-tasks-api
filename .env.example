# ===========================================
# Copy this file to .env and fill in values
# Never commit .env to version control
# ===========================================

# Server
PORT=8080

# Database (required)
DB_HOST=db
DB_PORT=5432
DB_USER=appuser
DB_PASSWORD=changeme
DB_NAME=appdb
DB_SSLMODE=disable

# Database connection pool (optional - defaults shown)
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=50
DB_CONN_MAX_LIFETIME_MINS=5
DB_CONN_MAX_IDLE_TIME_MINS=10

# Logging
# Options: development, production, quiet, silent
LOG_LEVEL=development

# CORS (comma-separated origins, no wildcards in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Timezone
TZ=Australia/Melbourne

# PostgreSQL container (used by compose.dev.yaml)
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme

# Valkey (Redis-compatible)
VALKEY_URL=valkey:6379
# Set if your Valkey is started with --requirepass; leave empty otherwise.
VALKEY_PASSWORD=

# JWT Configuration
JWT_ISSUER=go-tasks-api
JWT_AUDIENCE=go-tasks-api
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
